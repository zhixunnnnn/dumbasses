# Copy to backend/.env (git-ignored) and fill in. Never commit real secrets.
#
# Two feature sets read this file:
#   * AI Assistant  (chat / agent)        -> backend/app/agent.py
#   * ESG Evidence Engine (scoring/news)  -> backend/engine/*
# The ESG dashboard, Screener and tests run FULLY OFFLINE with no keys at all
# (deterministic mock LLM + seeded DB). Keys below only enable the LIVE paths.

# =============================================================================
# AI Assistant (OpenRouter) — REQUIRED for the chat/agent tab
# =============================================================================
# Without this, the server still boots but every assistant request returns
# HTTP 500 "OPENROUTER_API_KEY is not configured".
OPENROUTER_API_KEY=
# Optional — defaults to deepseek/deepseek-v4-flash
# OPENROUTER_MODEL=deepseek/deepseek-v4-flash

# =============================================================================
# Bright Data — live web scraping (assistant web tools + ESG news/prices)
# =============================================================================
# Mode A — API token (Web Unlocker / SERP / Scraper API):
BRIGHTDATA_API_KEY=
BRIGHTDATA_API_KEY_FALLBACK=
# Web Unlocker zone for the token path (default: web_unlocker1)
BRIGHTDATA_ZONE=web_unlocker1
# Dedicated SERP zone for the agent's web search (default: serp_api1).
# Falls back to the unlocker zone, then DuckDuckGo, if unset.
# BRIGHTDATA_SERP_ZONE=serp_api1

# Mode B — Proxy credentials (used by the ESG Scraping-Browser news path):
# BRIGHTDATA_PROXY=https://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:<port>
# Optional explicit Scraping-Browser CDP endpoint for JS-rendered pages:
# BRIGHTDATA_BROWSER_WSS=wss://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:9222

# Optional — set to 1 to make a failed scrape hard-fail instead of falling back.
# BRIGHTDATA_STRICT=1

# =============================================================================
# ESG claim extraction (LIVE mode only; the demo runs offline without these)
# =============================================================================
# OpenRouter (above) is reused for claim extraction when running online.
# Model override (default: deepseek/deepseek-chat):
# ESG_EXTRACTION_MODEL=deepseek/deepseek-chat
# Optional OpenAI fallback extractor:
OPENAI_API_KEY=
