# Copy to backend/.env (git-ignored) and fill in. Never commit real secrets.

# --- Bright Data: pick ONE mode ---
# Mode A — API token (Web Unlocker / Scraper API):
BRIGHTDATA_API_KEY=
BRIGHTDATA_API_KEY_FALLBACK=
BRIGHTDATA_ZONE=web_unlocker1
# Mode B — Proxy credentials (instead of the token above):
# BRIGHTDATA_PROXY=https://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:<port>
# Optional Scraping Browser endpoint for JS-rendered pages:
# BRIGHTDATA_BROWSER_WSS=wss://brd-customer-<id>-zone-<zone>:<password>@brd.superproxy.io:9222

# --- OpenAI (live claim extraction; optional, demo runs offline without it) ---
OPENAI_API_KEY=
